<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="カテゴリ管理"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/manage_income_categories_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="収入カテゴリの追加・編集・削除"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/manage_expense_categories_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="支出カテゴリの追加・編集・削除"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="支払い方法管理"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/manage_payment_methods_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="支払い方法の追加・編集・削除"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="予算設定"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/budget_settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="予算の設定"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="インポート"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/import_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CSVインポート"
        android:layout_marginTop="8dp" />

</LinearLayout>